    {
      "name": "Auth — Alice (register, refresh, logout)",
      "item": [
        {
          "name": "Register Alice",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.collectionVariables.set('alice_email', `alice.${Date.now()}.${Math.floor(Math.random()*10000)}@example.com`);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 201', () => pm.response.to.have.status(201));",
                  "const json = pm.response.json();",
                  "pm.test('returns access token', () => pm.expect(json.access_token).to.be.a('string').and.not.empty);",
                  "pm.collectionVariables.set('access_token_alice', json.access_token);",
                  "pm.collectionVariables.set('user_id_alice', json.user.id);",
                  "pm.test('sets a refresh_token cookie', () => {",
                  "  const cookie = pm.cookies.toObject()['refresh_token'];",
                  "  pm.expect(cookie).to.not.be.undefined;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{alice_email}}\",\n  \"password\": \"{{password}}\",\n  \"display_name\": \"Alice\",\n  \"invite_code\": \"{{invite_code}}\"\n}",
              "options": { "raw": { "language": "json" } }
