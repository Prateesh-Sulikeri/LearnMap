# Server
PORT=8080

# Database — matches docker-compose.yml's postgres service
DATABASE_URL=postgres://learnmap:learnmap_dev_password@localhost:5432/learnmap?sslmode=disable

# Auth
JWT_SECRET=change-me-to-a-long-random-string
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=30
REFRESH_COOKIE_NAME=refresh_token
REFRESH_COOKIE_DOMAIN=
REFRESH_COOKIE_SECURE=false

# Pilot registration gate (ADR-013) — required to POST /auth/register
INVITE_CODE=change-me-pilot-invite-code

# CORS — comma-separated origins allowed to send credentialed requests
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Uploads (images embedded in notes) — local disk for now, an MVP
# simplification; must move to persistent object storage before any
# production deploy to a host without a persistent filesystem.
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=5
